<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.alessandro_mattos.Purrify</id>
  <name>Purrify</name>
  <summary>Keep your desktop fresh and tidy</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <developer_name>Alessandro Mattos</developer_name>
  <description>
    <p>
      Purrify is a small, careful cleaner for elementary OS. It helps you review and remove unused files, Flatpak leftovers, thumbnails, and Trash with a light touch. Nothing is deleted without your approval.
    </p>
    <p>
      It stays local, avoids telemetry, and uses regular GTK APIs so it works on Wayland with an X11 fallback.
    </p>
  </description>
  <url type="donation">https://donate.stripe.com/cNicN42EFbHy54Y0P1frW00</url>
  <launchable type="desktop-id">io.github.alessandro_mattos.Purrify.desktop</launchable>
  <categories>
    <category>Utility</category>
  </categories>
  <releases>
    <release version="0.1.0" date="2026-07-01">
      <description>
        <p>Initial release with user-space cache, Trash and Flatpak leftover scanning.</p>
      </description>
    </release>
  </releases>
  <content_rating type="oars-1.1" />
</component>
