<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.alessandro_mattos.purrify</id>
  <name>Purrify</name>
  <summary>Review cleanup targets before deleting them</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <developer id="io.github.alessandro_mattos">
    <name>Alessandro Mattos</name>
  </developer>
  <description>
    <p>
      Purrify helps elementary OS users review common cleanup targets before removing anything: app caches, Trash, empty folders, broken shortcuts, and duplicate files.
    </p>
    <p>
      It stays local and uses limited Flatpak permissions. It does not use sudo, a background service, telemetry, or automatic deletion.
    </p>
  </description>
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/Alessandro-Mattos/Purrify/main/screenshots/01.png</image>
      <caption>Ready to scan</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/Alessandro-Mattos/Purrify/main/screenshots/02.png</image>
      <caption>Reviewing what can be cleaned, grouped by category</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/Alessandro-Mattos/Purrify/main/screenshots/03.png</image>
      <caption>Nothing is removed without an explicit confirmation</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/Alessandro-Mattos/Purrify/main/screenshots/04.png</image>
      <caption>Select only the items you want to clean</caption>
    </screenshot>
  </screenshots>
  <url type="homepage">https://github.com/Alessandro-Mattos/Purrify</url>
  <url type="bugtracker">https://github.com/Alessandro-Mattos/Purrify/issues</url>
  <url type="donation">https://donate.stripe.com/cNicN42EFbHy54Y0P1frW00</url>
  <launchable type="desktop-id">io.github.alessandro_mattos.purrify.desktop</launchable>
  <categories>
    <category>Utility</category>
  </categories>
  <releases>
    <release version="1.0.3" date="2026-07-15">
      <description>
        <p>Fixed the Flatpak manifest filename used by AppCenter review builds.</p>
      </description>
    </release>
    <release version="1.0.2" date="2026-07-15">
      <description>
        <p>Removed access to other Flatpak applications' private data while preserving user-space and developer cache cleanup.</p>
      </description>
    </release>
    <release version="1.0.1" date="2026-07-08">
      <description>
        <p>Grouped scan options into Apps &amp; Cache, Folders, and Duplicate files.</p>
        <p>Removed host Flatpak command access and limited Flatpak cleanup to local app caches.</p>
        <p>Updated screenshots and kept cleanup manual by default.</p>
      </description>
    </release>
    <release version="1.0.0" date="2026-07-04">
      <description>
        <p>Initial release with user-space cache, Trash, and Flatpak app cache scanning.</p>
      </description>
    </release>
  </releases>
