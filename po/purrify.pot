msgid "cleaner;flatpak;cache;trash;disk;space;elementary;"
msgstr ""

#: data/io.github.alessandro_mattos.purrify.metainfo.xml.in:8
msgid "Alessandro Mattos"
msgstr ""

#: data/io.github.alessandro_mattos.purrify.metainfo.xml.in:10
msgid ""
"Purrify is a small, careful cleaner for elementary OS. It helps you review "
"and remove unused files, Flatpak leftovers, thumbnails, and Trash with a "
"light touch. Nothing is deleted without your approval."
msgstr ""

#: data/io.github.alessandro_mattos.purrify.metainfo.xml.in:13
msgid ""
"It stays local, avoids telemetry, and uses regular GTK APIs so it works on "
"Wayland with an X11 fallback."
msgstr ""

#: data/io.github.alessandro_mattos.purrify.metainfo.xml.in:25
msgid ""
"Initial release with user-space cache, Trash and Flatpak leftover scanning."
msgstr ""
