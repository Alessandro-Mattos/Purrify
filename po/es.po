#: src/MainWindow.vala:79
msgid "A calm, safe cleaner"
msgstr "Un limpiador tranquilo y seguro"

#: src/MainWindow.vala:89
msgid "🐾 Feed the Cat"
msgstr ""

#: src/MainWindow.vala:90
msgid "Support Purrify"
msgstr ""

#: src/MainWindow.vala:95
msgid "Scan"
msgstr "Analizar"

#: src/MainWindow.vala:99
msgid "Clean Selected"
msgstr "Limpiar selección"

#: src/MainWindow.vala:116
msgid "Ready"
msgstr "Listo"

#: src/MainWindow.vala:123
msgid "Click Scan to look for safe things to clean."
msgstr "Haz clic en Analizar para buscar elementos seguros para limpiar."

#: src/MainWindow.vala:176
msgid "Scan options"
msgstr "Opciones de análisis"

#: src/MainWindow.vala:184
msgid "Caches & Trash"
msgstr "Cachés y papelera"

#: src/MainWindow.vala:192
msgid "Flatpak"
msgstr "Flatpak"

#: src/MainWindow.vala:200
msgid "Downloads"
msgstr "Descargas"

#: src/MainWindow.vala:209
msgid "Duplicate review (slower)"
msgstr "Revisión de duplicados (más lenta)"

#: src/MainWindow.vala:218
msgid "Developer tools"
msgstr "Herramientas de desarrollo"

#: src/MainWindow.vala:228
msgid ""
"Downloads and duplicate review can take longer on large folders. Your scan "
"choices are remembered locally."
msgstr ""
"Descargas y revisión de duplicados pueden tardar más en carpetas grandes. "
"Tus opciones de análisis se recuerdan localmente."

#: src/MainWindow.vala:260
msgid "Looking for safe things to clean…"
msgstr "Buscando elementos seguros para limpiar…"

#: src/MainWindow.vala:329
msgid "All clean"
msgstr "Todo limpio"

#: src/MainWindow.vala:330
msgid "Nothing safe to clean was found with the current scan options."
msgstr ""
"No se encontró nada seguro para limpiar con las opciones de análisis "
"actuales."

#: src/MainWindow.vala:331
msgid ""
"Try enabling Downloads, duplicate review, or Developer tools if you want a "
"broader review."
msgstr ""
"Activa Descargas, revisión de duplicados o Herramientas de desarrollo si "
"quieres una revisión más amplia."

#: src/MainWindow.vala:487
#, c-format
msgid "%d item found. Expand to choose individually."
msgid_plural "%d items found. Expand to choose individually."
msgstr[0] "%d elemento encontrado. expande para elegir individualmente."
msgstr[1] "%d elementos encontrados. expande para elegir individualmente."

#: src/MainWindow.vala:631
msgid "Nothing selected yet. Everything found is listed below."
msgstr "Aún no hay nada seleccionado. Todo lo encontrado aparece abajo."

#: src/MainWindow.vala:635
#, c-format
msgid "%d item selected. Nothing is removed until you confirm."
msgid_plural "%d items selected. Nothing is removed until you confirm."
msgstr[0] "%d elemento seleccionado. no se elimina nada hasta que confirmes."
msgstr[1] "%d elementos seleccionados. no se elimina nada hasta que confirmes."

#: src/MainWindow.vala:660
msgid "Select at least one item to clean."
msgstr "Selecciona al menos un elemento para limpiar."

#: src/MainWindow.vala:680
#, c-format
msgid ""
"This will permanently remove about %s and run %d command on your system. "
"This cannot be undone."
msgid_plural ""
"This will permanently remove about %s and run %d commands on your system. "
"This cannot be undone."
msgstr[0] ""
"Esto eliminará permanentemente alrededor de %s y ejecutará %d comando en tu "
"sistema. Esta acción no se puede deshacer."
msgstr[1] ""
"Esto eliminará permanentemente alrededor de %s y ejecutará %d comandos en tu "
"sistema. Esta acción no se puede deshacer."

#: src/MainWindow.vala:686
#, c-format
msgid "This will permanently remove about %s. This cannot be undone."
msgstr ""
"Esto eliminará permanentemente alrededor de %s. Esta acción no se puede "
"deshacer."

#: src/MainWindow.vala:693
#, c-format
msgid "Delete %d item?"
msgid_plural "Delete %d items?"
msgstr[0] "¿Eliminar %d elemento?"
msgstr[1] "¿Eliminar %d elementos?"

#: src/MainWindow.vala:704
msgid "Cancel"
msgstr "Cancelar"

#: src/MainWindow.vala:705
msgid "Delete"
msgstr "Eliminar"

#: src/MainWindow.vala:737
#, c-format
msgid "%s (%d item)"
msgid_plural "%s (%d items)"
msgstr[0] "%s (%d elemento)"
msgstr[1] "%s (%d elementos)"

#: src/MainWindow.vala:749
#, c-format
msgid "%d more category"
msgid_plural "%d more categories"
msgstr[0] "%d categoría más"
msgstr[1] "%d categorías más"

#: src/MainWindow.vala:755
#, c-format
msgid "Included: %s"
msgstr "Incluido: %s"

#: src/MainWindow.vala:763
msgid "Cleaning selected items…"
msgstr "Limpiando elementos seleccionados…"

#: src/MainWindow.vala:787 src/Cleaner.vala:35 src/Cleaner.vala:45
#, c-format
msgid "%s: %s"
msgstr "%s: %s"

#: src/MainWindow.vala:788
#, c-format
msgid "Failed to run %s: %s\n"
msgstr "No se pudo ejecutar %s: %s\n"

#: src/MainWindow.vala:814
#, c-format
msgid "Before: about %s selected. After: %s freed."
msgstr "Antes: alrededor de %s seleccionado. Después: %s liberados."

#: src/MainWindow.vala:818
msgid "Nothing was removed."
msgstr "No se eliminó nada."

#: src/MainWindow.vala:822
#, c-format
msgid "%d item could not be removed."
msgid_plural "%d items could not be removed."
msgstr[0] "No se pudo eliminar %d elemento."
msgstr[1] "No se pudieron eliminar %d elementos."

#: src/MainWindow.vala:830
#, c-format
msgid "%d item cleaned"
msgid_plural "%d items cleaned"
msgstr[0] "%d elemento limpiado"
msgstr[1] "%d elementos limpiados"

#: src/MainWindow.vala:837
#, c-format
msgid "%d command completed"
msgid_plural "%d commands completed"
msgstr[0] "%d comando completado"
msgstr[1] "%d comandos completados"

#: src/MainWindow.vala:843
#, c-format
msgid ""
"%s. %s freed in total since you installed Purrify.%s If it saved you some "
"hassle, a good rating helps a lot."
msgstr ""
"%s. %s liberados en total desde que instalaste Purrify.%s Si te ahorró "
"molestias, una buena valoración ayuda mucho."

#: src/MainWindow.vala:849
#, c-format
msgid "Nothing to report.%s"
msgstr "Nada que informar.%s"

#: src/MainWindow.vala:866
msgid "Could not remove: "
msgstr "No se pudo eliminar: "

#: src/MainWindow.vala:881
#, c-format
msgid "%d more failure"
msgid_plural "%d more failures"
msgstr[0] "%d fallo más"
msgstr[1] "%d fallos más"

#: src/MainWindow.vala:894
msgid "No cleanup history yet."
msgstr "Aún no hay historial de limpiezas."

#: src/MainWindow.vala:898
msgid "Recent cleanups: "
msgstr "Limpiezas recientes: "

#: src/MainWindow.vala:902
#, c-format
msgid "%s freed on %s"
msgstr "%s liberados el %s"

#: src/MainWindow.vala:909
#, c-format
msgid "(%d failure)"
msgid_plural "(%d failures)"
msgstr[0] "(%d fallo)"
msgstr[1] "(%d fallos)"

#: src/Scanner.vala:24
msgid "Thumbnails cache"
msgstr "Caché de miniaturas"

#: src/Scanner.vala:25
msgid "Cached image previews generated by file managers and apps."
msgstr ""
"Vistas previas de imágenes en caché generadas por gestores de archivos y "
"aplicaciones."

#: src/Scanner.vala:35
msgid "Trash files"
msgstr "Archivos de la papelera"

#: src/Scanner.vala:36
msgid "Files currently stored in your local Trash folder."
msgstr "Archivos almacenados actualmente en tu carpeta local de la Papelera."

#: src/Scanner.vala:46
msgid "Trash metadata"
msgstr "Metadatos de la papelera"

#: src/Scanner.vala:47
msgid "Metadata used by the local Trash folder."
msgstr "Metadatos usados por la carpeta local de la Papelera."

#: src/Scanner.vala:64
msgid "Unused Flatpak runtimes"
msgstr "Runtimes de Flatpak no usados"

#: src/Scanner.vala:65
msgid ""
"Runtimes no installed app uses anymore. Safe to remove. Flatpak will "
"download them again if a future app needs them."
msgstr ""
"Runtimes que ya no usa ninguna aplicación instalada. Es seguro eliminarlos. "
"Flatpak los descargará de nuevo si una aplicación futura los necesita."

#: src/Scanner.vala:118
msgid "Python package cache (pip)"
msgstr "Caché de paquetes Python (pip)"

#: src/Scanner.vala:119
msgid ""
"Downloaded Python packages pip already installed. pip re-downloads them if "
"needed again."
msgstr ""
"Paquetes Python descargados que pip ya instaló. pip los volverá a descargar "
"si los necesita."

#: src/Scanner.vala:124 src/Scanner.vala:136 src/Scanner.vala:148
msgid "Developer tool caches"
msgstr "Cachés de herramientas de desarrollo"

#: src/Scanner.vala:130
msgid "Node package cache (npm)"
msgstr "Caché de paquetes Node (npm)"

#: src/Scanner.vala:131
msgid ""
"Downloaded Node.js packages npm already installed. npm re-downloads them if "
"needed again."
msgstr ""
"Paquetes Node.js descargados que npm ya instaló. npm los volverá a descargar "
"si los necesita."

#: src/Scanner.vala:142
msgid "Node package cache (Yarn)"
msgstr "Caché de paquetes Node (Yarn)"

#: src/Scanner.vala:143
msgid ""
"Downloaded Node.js packages Yarn already installed. Yarn re-downloads them "
"if needed again."
msgstr ""
"Paquetes Node.js descargados que Yarn ya instaló. Yarn los volverá a "
"descargar si los necesita."

#: src/Scanner.vala:187
#, c-format
msgid "Crash reports: %s"
msgstr "Informes de fallos: %s"

#: src/Scanner.vala:188
msgid ""
"Diagnostic crash dumps left behind by an app. Safe to remove; only useful "
"for debugging that app."
msgstr ""
"Volcados de diagnóstico dejados por una aplicación. Es seguro eliminarlos; "
"solo sirven para depurar esa aplicación."

#: src/Scanner.vala:194
msgid "Crash reports"
msgstr "Informes de fallos"

#: src/Scanner.vala:227
#, c-format
msgid "App cache: %s"
msgstr "Caché de la aplicación: %s"

#: src/Scanner.vala:228
msgid ""
"Cache used by an app you still have installed. The app recreates it as "
"needed."
msgstr ""
"Caché usada por una aplicación que aún tienes instalada. La aplicación la "
"recrea cuando la necesita."

#: src/Scanner.vala:234
msgid "Flatpak app caches"
msgstr "Cachés de aplicaciones Flatpak"

#: src/Scanner.vala:279
#, c-format
msgid "Flatpak leftover: %s"
msgstr "Resto de Flatpak: %s"

#: src/Scanner.vala:280
msgid ""
"Data left behind by an app that does not appear in the installed Flatpak app "
"list."
msgstr ""
"Datos dejados por una aplicación que no aparece en la lista de aplicaciones "
"Flatpak instaladas."

#: src/Scanner.vala:286
msgid "Flatpak leftovers"
msgstr "Restos de Flatpak"

#: src/Scanner.vala:415
#, c-format
msgid "Duplicate: %s"
msgstr "Duplicado: %s"

#: src/Scanner.vala:416
#, c-format
msgid ""
"Identical to %s, already in Downloads. This check can be slow on large "
"folders, so duplicates are left unselected for review."
msgstr ""
"Idéntico a %s, ya en Descargas. Esta comprobación puede ser lenta en "
"carpetas grandes, por eso los duplicados quedan sin seleccionar para "
"revisión."

#: src/Scanner.vala:422
msgid "Duplicate files"
msgstr "Archivos duplicados"

#: src/Scanner.vala:587
#, c-format
msgid "Empty folder: %s"
msgstr "Carpeta vacía: %s"

#: src/Scanner.vala:588
msgid "Leftover empty folder, likely from an extracted or moved download."
msgstr ""
"Carpeta vacía sobrante, probablemente de una descarga extraída o movida."

#: src/Scanner.vala:595
msgid "Empty folders"
msgstr "Carpetas vacías"

#: src/Scanner.vala:649
#, c-format
msgid "Broken shortcut: %s"
msgstr "Acceso directo roto: %s"

#: src/Scanner.vala:650
msgid "A shortcut pointing to a file or folder that no longer exists."
msgstr "Un acceso directo que apunta a un archivo o carpeta que ya no existe."

#: src/Scanner.vala:657
msgid "Broken shortcuts"
msgstr "Accesos directos rotos"

#: src/Cleaner.vala:57
msgid "Empty paths cannot be removed."
msgstr "No se pueden eliminar rutas vacías."

#: src/Cleaner.vala:65
msgid "Refusing to remove a broad system or home path."
msgstr ""
"Se rechaza eliminar una ruta amplia del sistema o de la carpeta personal."

#: src/Cleaner.vala:100
msgid "Path is outside Purrify's allowed cleanup locations."
msgstr ""
"La ruta está fuera de las ubicaciones de limpieza permitidas por Purrify."

#: src/Cleaner.vala:148
msgid "Command is not in Purrify's allowed command list."
msgstr "El comando no está en la lista de comandos permitidos por Purrify."

#: src/Cleaner.vala:175
msgid "The command exited with an error."
msgstr "El comando terminó con un error."

